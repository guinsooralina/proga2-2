from abc import ABC, abstractmethod
from typing import Optional


class AbstractClass(ABC):
    """
    Абстрактный класс определяет шаблонный метод, содержащий скелет некоторого алгоритма.
    Конкретные подклассы должны реализовать эти операции, но оставить сам шаблонный метод без изменений.

    AbstractClass (Базовый класс)
    - Определяет шаблонный метод template_method(), который задаёт структуру алгоритма
    - Предоставляет конкретные методы с реализацией по умолчанию (base_operation1, base_operation2, base_operation3)
    - Объявляет абстрактные методы, которые обязательно должны быть реализованы в подклассах (required_operations1, required_operations2)
    - Определяет хуки (hook1, hook2) - опциональные методы, которые подклассы могут переопределить при необходимости

    В контексте библиотечной задачи:
    Этот класс представляет общую процедуру обслуживания читателя, которая не зависит от типа читателя.
    """

    def template_method(self) -> None:
        """
        Шаблонный метод определяет скелет алгоритма. Этот метод никогда не меняется в подклассах.
        Все подклассы используют его в неизменном виде, переопределяя только отдельные шаги.

        В задаче: Полная процедура обслуживания читателя.
        Порядок шагов стандартизирован и не может быть изменён в подклассах.
        """
        self.base_operation1()
        self.required_operations1()
        self.base_operation2()
        self.hook1()
        self.required_operations2()
        self.base_operation3()
        self.hook2()

    def base_operation1(self) -> None:
        """
        Конкретный метод №1 с реализацией по умолчанию.

        Concrete Method (Конкретный метод). Имеет реализацию по умолчанию, может быть переопределён в подклассах.
        Обычно содержит общую логику для всех подклассов.

        В задаче: Проверка читательского билета и аутентификация.
        Этот шаг одинаков для всех типов читателей.
        """
        pass

    def base_operation2(self) -> None:
        """
        Конкретный метод №2 с реализацией по умолчанию.

        Concrete Method (Конкретный метод). Может быть переопределён, но не обязателен для переопределения

        В задаче: Оформление записи в электронном журнале.
        Базовая реализация подходит для всех случаев.
        """
        pass

    def base_operation3(self) -> None:
        """
        Конкретный метод №3 с реализацией по умолчанию.

        Concrete Method (Конкретный метод). Заключительный шаг алгоритма с общей реализацией

        В библиотечной задаче: Фиксация выдачи и обновление базы данных.
        """
        pass

    @abstractmethod
    def required_operations1(self) -> None:
        """
        Абстрактный метод №1 - обязателен для реализации в подклассах.

        Abstract Method (Абстрактный метод). Не имеет реализации в базовом классе.
        Каждый конкретный подкласс обязан предоставить свою реализацию.
        Обычно содержит специфическое поведение для каждого подкласса.

        В задаче: Поиск книги в каталоге.

        """
        pass

    @abstractmethod
    def required_operations2(self) -> None:
        """
        Абстрактный метод №2 - обязателен для реализации в подклассах.

        Abstract Method (Абстрактный метод). Второй обязательный шаг, специфичный для каждого подкласса

        В задаче: Проверка возможности выдачи книги.
        """
        pass

    def hook1(self) -> None:
        """
        Хук №1 - опциональный метод с пустой реализацией.

        Hook (Хук). Имеет пустую реализацию по умолчанию. Подклассы могут переопределить, но не обязаны.
        Используется для добавления дополнительного поведения без изменения алгоритма.

        В задаче: Отправка напоминания о дате возврата.
        Не для всех читателей нужно напоминание.
        """
        pass

    def hook2(self) -> None:
        """
        Хук №2 - опциональный метод с пустой реализацией.

        В задаче: Печать читательского талона.
        Дополнительная услуга, не обязательная для всех.
        """
        pass


