def client_code(abstract_class: AbstractClass) -> None:
    """
    Клиентский код должен работать с объектами через интерфейс AbstractClass.
    Клиенту не нужно знать, какой именно конкретный класс используется.

    Client (Клиент). Вызывает шаблонный метод через интерфейс базового класса.
    Не зависит от конкретных подклассов.

    В задаче: библиотекарь
    Библиотекарь просто вызывает процедуру обслуживания, не важно,
    обычный читатель перед ним или читатель читального зала.
    Все специфические шаги выполняются автоматически.
    """
    abstract_class.template_method()


